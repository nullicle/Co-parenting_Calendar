{
  "name": "functions",
  "private": true,
  "main": "lib/index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "build": "tsc",
    "serve": "npm run build && npx firebase emulators:start --only functions,firestore",
    "shell": "npm run build && npx firebase functions:shell",
    "deploy": "npx firebase deploy --only functions",
    "logs": "npx firebase functions:log",
    "send-test-notification": "npm run build && node lib/scripts/send-test-notification.js"
  },
  "dependencies": {
    "firebase-admin": "^12.6.0",
    "firebase-functions": "^6.0.1"
  },
  "devDependencies": {
    "firebase-tools": "^13.20.2",
    "typescript": "^5.5.4"
  }
}
